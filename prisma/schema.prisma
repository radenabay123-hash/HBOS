// HAFARA BUSINESS OPERATING SYSTEM (HBOS)
// Prisma schema - SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================== USERS & AUTH =====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("STAFF") // OWNER, PROJECT_MANAGER, ASSISTANT_TRAINER, CONTENT_CREATIVE, DIGITAL_MARKETING_IT, FINANCE
  phone        String?
  avatar       String?
  position     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients          Client[]
  events           Event[]
  tasks            DailyTask[]
  contentIdeas     ContentIdea[]
  articles         Article[]
  financeTxns      FinanceTransaction[]
  documents        Document[]
  scoredBy         ScoreLog[]         @relation("ScoreLogScorer")
  scoredTarget     ScoreLog[]         @relation("ScoreLogTarget")
  sessions         Session[]
  notifications    Notification[]
  kpiLogs          KpiLog[]
  attendances      Attendance[]
  salaryConfig     SalaryConfig?
  payrolls         Payroll[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===================== CRM CLIENT MANAGEMENT =====================

model Client {
  id              String   @id @default(cuid())
  namaKlien       String
  instansi        String?
  pic             String?
  nomorWA         String?
  email           String?
  jenisTraining   String?
  jumlahPeserta   Int?
  budget          Float?
  lokasi          String?
  tanggalEvent    DateTime?
  status          String   @default("LEAD") // LEAD, FOLLOW_UP, PROPOSAL, NEGOTIATION, DEAL, LOST
  catatanFollowUp String?
  reminderFollowUp DateTime?
  assignedToId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedTo      User?       @relation(fields: [assignedToId], references: [id])
  events          Event[]
  documents       Document[]
  financeTxns     FinanceTransaction[]

  @@index([status])
  @@index([assignedToId])
}

// ===================== EVENT MANAGEMENT =====================

model Event {
  id              String   @id @default(cuid())
  namaEvent       String
  clientId        String?
  tanggal         DateTime
  lokasi          String?
  trainer         String?
  assistantTrainerId String?
  statusPersiapan String   @default("PENDING") // PENDING, IN_PROGRESS, READY, COMPLETED
  checklist       String?  // JSON array of {item, done}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client?  @relation(fields: [clientId], references: [id])
  assistantTrainer User?   @relation(fields: [assistantTrainerId], references: [id])

  @@index([tanggal])
}

// ===================== DAILY TASK MANAGEMENT =====================

model DailyTask {
  id              String   @id @default(cuid())
  userId          String
  taskHariIni     String
  progress        String?
  persentaseSelesai Int    @default(0)
  hambatan        String?
  jamMulai        String?
  jamSelesai      String?
  status          String   @default("BELUM") // BELUM, SEDANG, SELESAI
  tanggal         DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tanggal])
}

// ===================== CONTENT IDEAS (ACC WORKFLOW) =====================

model ContentIdea {
  id              String   @id @default(cuid())
  userId          String
  // Kategori: Instagram M. Aqil Baihaqi, TikTok Aqil Baihaqi, Hafara Group, MentorSkill
  kategori        String
  judul           String
  link            String?
  ideKonten       String?
  script          String?
  caption         String?
  // Produksi
  statusProduksi  String   @default("IDE") // IDE, PRODUKSI, EDITING, SIAP_PUBLISH, PUBLISHED
  statusEditing   String   @default("PENDING") // PENDING, IN_PROGRESS, DONE
  statusPublish   String   @default("PENDING") // PENDING, PUBLISHED
  linkKonten      String?
  metrikKonten    String?  // JSON {reach, views, watchTime, share, save, comment, followerGrowth}
  // ACC workflow dari owner
  statusACC       String   @default("PENDING") // PENDING, ACC, REVISI
  catatanRevisi   String?
  accAt           DateTime?
  accById         String?
  tanggal         DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([kategori])
  @@index([statusACC])
  @@index([statusPublish])
}

// ===================== SEO ARTICLE MANAGEMENT =====================

model Article {
  id              String   @id @default(cuid())
  userId          String
  judulArtikel    String
  keyword         String?
  websiteTujuan   String?
  tanggalPublish  DateTime?
  linkArtikel     String?
  // ACC workflow
  statusACC       String   @default("PENDING") // PENDING, ACC, REVISI_ADMIN
  catatanRevisi   String?
  accAt           DateTime?
  accById         String?
  status          String   @default("DRAFT") // DRAFT, PUBLISHED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([statusACC])
  @@index([status])
}

// ===================== FINANCE =====================

model FinanceTransaction {
  id              String   @id @default(cuid())
  type            String   // PEMASUKAN, PENGELUARAN, TRANSFER
  amount          Float
  description     String?
  category        String?  // category key (FinanceCategory)
  subCategory     String?  // free text
  accountType     String   @default("KAS") // KAS, BANK, EWALLET
  accountName     String?  // e.g. "BCA 123456", "OVO", "Kas Besar"
  date            DateTime @default(now())
  userId          String
  clientId        String?
  attachmentUrl   String?  // bukti transaksi (invoice/kwitansi/nota)
  isTaxable       Boolean  @default(false)
  taxType         String?  // PPH21, PPH23, PPH_BADAN, PPN
  taxAmount       Float    @default(0)
  taxIncluded     Boolean  @default(false) // tax included in nominal
  isPaid          Boolean  @default(true) // for piutang/hutang: false = outstanding
  dueDate         DateTime?
  vendorName      String?  // for pengeluaran
  // Additional fields for form (sesuai gambar)
  kontakName      String?  // kontak (klien/vendor)
  projectName     String?  // proyek
  trainerName     String?  // trainer/konsultan
  invoiceNumber   String?  // no. invoice
  receiptNumber   String?  // no. kwitansi
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client          Client?  @relation(fields: [clientId], references: [id])

  @@index([type])
  @@index([date])
  @@index([userId])
  @@index([category])
  @@index([accountType])
}

model FinanceSetting {
  id              String   @id @default(cuid())
  targetRevenue   Float    @default(500000000)
  targetProfit    Float    @default(150000000)
  month           Int      // 1-12
  year            Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([month, year])
}

// ===================== DOCUMENTS (SURAT, INVOICE, SPK, dll) =====================

model Document {
  id              String   @id @default(cuid())
  clientId        String?
  documentType    String   // SURAT, INVOICE, SPK, KONTRAK, LAINNYA (custom)
  documentName    String
  documentNumber  String?
  link            String
  description     String?
  uploadedById    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client?  @relation(fields: [clientId], references: [id])
  uploadedBy      User     @relation(fields: [uploadedById], references: [id])

  @@index([clientId])
  @@index([documentType])
}

// ===================== SCOREBOARD =====================

model ScoreLog {
  id              String   @id @default(cuid())
  scorerId        String   // who awarded
  targetUserId    String   // who received
  points          Int
  reason          String?
  category        String   // PRODUKTIF, DISIPLIN, KERJA_SAMA, etc
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  scorer          User     @relation("ScoreLogScorer", fields: [scorerId], references: [id])
  targetUser      User     @relation("ScoreLogTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([date])
}

// ===================== NOTIFICATIONS =====================

model Notification {
  id              String   @id @default(cuid())
  userId          String
  title           String
  message         String
  type            String   @default("INFO") // INFO, ACC, REVISI, TASK, REMINDER
  read            Boolean  @default(false)
  link            String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===================== KPI LOGS (Daily/Weekly/Monthly Achievement Tracking) =====================

model KpiLog {
  id              String   @id @default(cuid())
  userId          String
  metricKey       String   // e.g. pm_artikel_kota, at_ide_konten
  value           Float    // actual achievement value
  date            DateTime @default(now())
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metricKey, date])
  @@index([userId])
  @@index([metricKey])
  @@index([date])
}

// ===================== ATTENDANCE (ABSENSI) =====================

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("HADIR") // HADIR, TERLAMBAT, IZIN, SAKIT, ALPHA, CUTI
  workHours   Float?   // calculated hours
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ===================== SALARY CONFIG (GAJI POKOK) =====================

model SalaryConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  baseSalary          Float    @default(5000000)
  mealAllowance       Float    @default(0)
  transportAllowance  Float    @default(0)
  bonusTarget         Float    @default(0)  // bonus if KPI >= 90
  penaltyPerAbsent    Float    @default(0)  // penalty per day absent
  bpjs                Float    @default(0)
  tax                 Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===================== PAYROLL (SLIP GAJI) =====================

model Payroll {
  id                  String   @id @default(cuid())
  userId              String
  month               Int
  year                Int
  baseSalary          Float
  mealAllowance       Float    @default(0)
  transportAllowance  Float    @default(0)
  workingDays         Int      @default(0)
  presentDays         Int      @default(0)
  absentDays          Int      @default(0)
  lateDays            Int      @default(0)
  leaveDays           Int      @default(0)
  kpiScore            Float    @default(0)
  kpiBonus            Float    @default(0)
  attendanceDeduction Float    @default(0)
  bpjs                Float    @default(0)
  tax                 Float    @default(0)
  otherDeduction      Float    @default(0)
  grossSalary         Float
  totalDeduction      Float    @default(0)
  netSalary           Float
  status              String   @default("DRAFT") // DRAFT, APPROVED, PAID
  paidAt              DateTime?
  note                String?
  // Manual input & slip gaji fields
  isManual            Boolean  @default(false)
  nik                 String?
  jabatan             String?
  bankName            String?
  bankAccount         String?
  accountName         String?
  periodeLabel        String?
  companyName         String?  @default("PT. HAFARA AIQBA NUSANTARA")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
}

// ===================== FINANCE CATEGORIES =====================

model FinanceCategory {
  id          String   @id @default(cuid())
  name        String
  type        String   // PEMASUKAN, PENGELUARAN
  icon        String?  // lucide icon name
  color       String?  // tailwind color
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([name, type])
}

// ===================== INVENTORY (ASET) =====================

model Inventory {
  id              String   @id @default(cuid())
  name            String
  category        String   // LAPTOP, KAMERA, PRINTER, MOBIL, MOTOR, MEJA, KURSI, PROYEKTOR, MONITOR, LAINNYA
  photoUrl        String?
  qrCode          String?
  location        String?
  pic             String?  // person in charge
  purchaseDate    DateTime
  purchasePrice   Float
  usefulLife      Int      // umur ekonomis (tahun)
  depreciationMethod String @default("STRAIGHT_LINE") // STRAIGHT_LINE
  currentValue    Float    @default(0) // calculated
  accumulatedDepreciation Float @default(0)
  status          String   @default("AKTIF") // AKTIF, MAINTENANCE, RUSAK, DIJUAL
  notes           String?
  nextMaintenance DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements       AssetMovement[]

  @@index([category])
  @@index([status])
}

model AssetMovement {
  id          String   @id @default(cuid())
  assetId     String
  fromLocation String?
  toLocation  String
  fromPic     String?
  toPic       String?
  reason      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  asset       Inventory @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

// ===================== TAX CONFIG (Indonesia) =====================
// Config-driven tax rates - can be updated without code changes

model TaxConfig {
  id              String   @id @default(cuid())
  taxType         String   // PPH21, PPH23, PPH_BADAN, PPN
  name            String
  rate            Float    // percentage (e.g. 0.5 for PPh 23, 11 for PPN, 22 for PPh Badan)
  description     String?
  effectiveFrom   DateTime @default(now())
  isActive        Boolean  @default(true)
  // For PPh 21 progressive brackets (stored as JSON)
  brackets        String?  // JSON: [{min, max, rate}]
  // PTKP (untuk PPh 21)
  ptkp            String?  // JSON: {TK0, TK1, K0, K1, K2, K3...}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([taxType])
}

// ===================== TAX PAYMENT (Pajak Terutang & Pembayaran) =====================

model TaxPayment {
  id              String   @id @default(cuid())
  taxType         String   // PPH21, PPH23, PPH_BADAN, PPN
  period          String   // e.g. "2026-07" atau "2026-Q3"
  periodType      String   // BULANAN, KUARTAL, TAHUNAN
  masaPajak       String?  // Januari 2026, etc
  taxableAmount   Float    // dasar pengenaan pajak
  taxRate         Float    // tarif yang dipakai
  taxDue          Float    // pajak terutang
  taxPaid         Float    @default(0) // sudah dibayar
  status          String   @default("TERUTANG") // TERUTANG, DIBAYAR, DILAPORKAN
  dueDate         DateTime // jatuh tempo
  paidAt          DateTime?
  reportedAt      DateTime?
  npwp            String?
  notes           String?
  // Dokumen
  buktiPotongUrl  String?
  buktiBayarUrl   String?
  dokumenUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([taxType])
  @@index([period])
  @@index([status])
}

// ===================== AI CHAT HISTORY (Finance Assistant & Tax Consultant) =====================

model AiChatHistory {
  id          String   @id @default(cuid())
  userId      String
  sessionType String   // FINANCE_ASSISTANT, TAX_CONSULTANT
  role        String   // user, assistant
  content     String
  createdAt   DateTime @default(now())

  @@index([userId, sessionType])
}

// ===================== INVOICE =====================

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  issueDate       DateTime
  clientName      String
  clientAddress   String?
  city            String?  // kota penerbitan
  description     String?  // deskripsi produk/layanan utama
  // Items stored as JSON: [{description, qty, price, total}]
  items           String
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  tax             Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("PENDING") // PENDING, PAID, CANCELLED
  paymentInstruction String?
  terms           String?
  note            String?
  // Bank info
  bankName        String?
  bankAccount     String?
  accountName     String?
  // Creator
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([issueDate])
}

// ===================== APP SETTING (Configurable application settings) =====================

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   @default("GENERAL") // GENERAL, COMPANY, FINANCE, TAX, APPEARANCE
  type        String   @default("TEXT") // TEXT, NUMBER, BOOLEAN, IMAGE, JSON
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
